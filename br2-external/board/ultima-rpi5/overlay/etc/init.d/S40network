#!/bin/sh
#
# Start WiFi networking
#

LOG="/boot/ultima-debug.log"

case "$1" in
    start)
        echo "Starting WiFi..."
        echo "=== S40network start: $(date) ===" >> "$LOG"

        echo "--- dmesg brcmfmac/wifi ---" >> "$LOG"
        dmesg | grep -iE "brcm|wifi|wlan|mmc|sdio|firm" >> "$LOG" 2>&1

        echo "--- firmware files ---" >> "$LOG"
        ls -la /lib/firmware/brcm/brcmfmac43455* >> "$LOG" 2>&1
        ls -la /lib/firmware/cypress/cyfmac43455* >> "$LOG" 2>&1

        echo "--- ip link ---" >> "$LOG"
        ip link >> "$LOG" 2>&1

        echo "--- Starting wpa_supplicant ---" >> "$LOG"
        wpa_supplicant -B -i wlan0 -c /etc/wpa_supplicant/wpa_supplicant.conf >> "$LOG" 2>&1
        echo "wpa_supplicant exit code: $?" >> "$LOG"

        sleep 2

        echo "--- Starting udhcpc ---" >> "$LOG"
        udhcpc -i wlan0 -b -q >> "$LOG" 2>&1
        echo "udhcpc exit code: $?" >> "$LOG"

        sleep 2

        echo "--- ip addr ---" >> "$LOG"
        ip addr >> "$LOG" 2>&1
        ;;
    stop)
        echo "Stopping WiFi..."
        killall -q wpa_supplicant 2>/dev/null
        killall -q udhcpc 2>/dev/null
        ifconfig wlan0 down 2>/dev/null
        ;;
    restart)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
