#!/bin/sh
#
# Mount the boot (FAT32) partition for debug log access from macOS
#

case "$1" in
    start)
        echo "Mounting boot partition..."
        mkdir -p /boot

        # Derive boot partition from the root device the kernel mounted
        # e.g. /dev/sda2 -> /dev/sda1, /dev/mmcblk0p2 -> /dev/mmcblk0p1
        ROOT_DEV=$(awk '$2 == "/" {print $1}' /proc/mounts)
        BOOT_DEV=$(echo "$ROOT_DEV" | sed 's/2$/1/')

        if [ -b "$BOOT_DEV" ]; then
            mount -t vfat "$BOOT_DEV" /boot 2>/dev/null && exit 0
        fi

        # Fallback: try common device names
        for dev in /dev/sda1 /dev/mmcblk0p1 /dev/nvme0n1p1; do
            if [ -b "$dev" ]; then
                mount -t vfat "$dev" /boot 2>/dev/null && exit 0
            fi
        done

        echo "S05bootmount: FAILED (root=$ROOT_DEV boot=$BOOT_DEV)" > /dev/tty1 2>/dev/null
        ;;
    stop)
        umount /boot 2>/dev/null
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
